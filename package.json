{
  "name": "@boltstore/client",
  "version": "0.5.0",
  "description": "TypeScript SDK for Boltstore \u2014 works in Bun, Node 18+, browsers, React Native",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "boltstore": "./src/typegen/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./adapters/node": "./src/adapters/node.ts",
    "./adapters/web": "./src/adapters/web.ts",
    "./adapters/react-native": "./src/adapters/react-native.ts",
    "./typegen": "./src/typegen/cli.ts"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test",
    "check": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@boltstore/utils": "^0.5.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "boltstore",
    "sdk",
    "client",
    "baas",
    "offline",
    "sync"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boltstore/client"
  }
}
